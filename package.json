{
  "name": "myhacktimer",
  "version": "1.0.2",
  "description": "Smart CLI that tracks only real active coding time per project",
  "main": "dist/index.js",
  "bin": {
    "hacktimer": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest --run"
  },
  "keywords": [
    "productivity",
    "timer",
    "cli",
    "developer-tools",
    "time-tracking"
  ],
  "author": "thejamesnick",
  "license": "MIT",
  "vitest": {
    "environment": "node"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.0",
    "commander": "^11.0.0"
  }
}
